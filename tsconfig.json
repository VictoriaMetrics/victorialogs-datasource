{
  "compilerOptions": {
    "jsx": "react",
    "baseUrl": "/",
    "outDir": "victorialogs-datasource",
    "rootDirs": ["/"],
    "allowJs": true,
    "strict": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": true,
    "incremental": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "target": "es5",
      "esModuleInterop": true,
      "moduleResolution": "node10"
    },
    "transpileOnly": true
  },
  "extends": "./.config/tsconfig.json",
}
